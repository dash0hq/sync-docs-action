{
  "$schema": "https://json.schemastore.org/prettierrc",
  "useTabs": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "singleQuote": false,
  "semi": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "printWidth": 100,
  "overrides": [
    {
      "files": ["*.json", "*.jsonc", "*.yml", "*.yaml", "*.md"],
      "options": {
        "useTabs": false,
        "tabWidth": 2
      }
    }
  ]
}
